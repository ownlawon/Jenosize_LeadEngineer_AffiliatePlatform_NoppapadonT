# --- API ---
NODE_ENV=development
API_PORT=3001
API_BASE_URL=http://localhost:3001

DATABASE_URL=postgresql://jenosize:jenosize@localhost:5432/jenosize?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-me-with-strong-secret
JWT_EXPIRES_IN=7d

# Seed admin (created on first boot if no users exist)
ADMIN_EMAIL=admin@jenosize.test
ADMIN_PASSWORD=ChangeMe!2025

# Public base URL for short links (used in API responses + frontend display)
SHORT_LINK_BASE_URL=http://localhost:3001

# Web app origin allowed by api CORS. In production set this to the public web URL.
WEB_ORIGIN_URL=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_PORT=3000
